{
  "name": "simplest-sdd",
  "version": "0.7.0",
  "description": "An approval-gated spec-driven workflow with integrated planning, model-agnostic execution routing, and execution analytics.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marcebollin/simplest-sdd.git"
  },
  "homepage": "https://github.com/marcebollin/simplest-sdd#readme",
  "bugs": {
    "url": "https://github.com/marcebollin/simplest-sdd/issues"
  },
  "type": "module",
  "bin": {
    "simplest-sdd": "bin/simplest-sdd.mjs"
  },
  "files": [
    "bin",
    "lib",
    "docs",
    "examples",
    "prompts",
    "schema",
    "PROMPT.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "rsbuild dev --port 3010",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "deploy": "rsbuild build && wrangler deploy",
    "test": "node --test"
  },
  "keywords": [
    "agents",
    "claude",
    "codex",
    "orchestration",
    "analytics",
    "spec-driven-development",
    "sdd"
  ],
  "author": "Marcelo Leon",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@rsbuild/core": "^2.1.6",
    "@rsbuild/plugin-react": "^2.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "wrangler": "^4.112.0"
  }
}
