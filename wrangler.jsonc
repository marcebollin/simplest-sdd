{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "simplest-sdd",
  "compatibility_date": "2026-07-22",
  "workers_dev": true,
  "preview_urls": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "sd2.marcebollin.com",
      "custom_domain": true
    }
  ],
  "send_metrics": false
}
